# Pin the pnpm content-addressable store to the path mounted in the
# devcontainer (see .devcontainer/devcontainer.json sunpub_pnpm_store
# volume). Without this, pnpm defaults to `<workspace>/.pnpm-store/`
# which lives inside the bind-mounted repo and isn't cached across
# container rebuilds — every rebuild re-downloads every dependency.
store-dir=/root/.local/share/pnpm/store
