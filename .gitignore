# Dependencies
node_modules/
.venv/
.pnpm-store/

# Build output
dist/

# Data (generated by pipeline or too large for git)
# Use /data/* (not /data/) so we can re-include specific files via `!`.
# When you gitignore a directory, its contents can't be brought back —
# you have to exclude the contents and re-include the keepers.
/data/*
!/data/.gitkeep
# Slug lock IS committed — it locks every published per-pub URL slug so they
# stay stable across machines, CI runs, and contributors. Tiny file, append-
# only by match_plots.py, never edited by hand.
!/data/slug_lock.json
# Reference data for explore pages (small, rarely changes).
!/data/county_map.json
!/data/ons_to_county.json
!/data/ons_counties.geojson
!/data/ons_countries.geojson
# Lastmod state IS committed for the same reason — it tracks per-URL hashes
# so the sitemap only bumps `<lastmod>` for genuinely-changed URLs across
# CI runs, instead of telling Google to recrawl everything every release.
!/data/lastmod_state.json

# Wrangler local dev cache (workerd binaries, function build artefacts)
.wrangler/

# Environment
.env
.env.local

# IDE
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.pyc

# Legacy app (old FastAPI stack, kept locally for reference)
app/

# Reference repos
ref/

# Pipeline-generated data — all served from R2 (data.sunny-pint.co.uk).
# Local copies in public/data/ are for dev only (Vite serves them).
public/data/pubs.json
public/data/pubs-index.json
public/data/buildings.pmtiles
public/data/tiles/
public/data/detail/
public/data/og/

# PWA generated
dev-dist/
